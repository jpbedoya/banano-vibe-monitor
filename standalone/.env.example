# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=                        # Bot token from Discord developer portal

# ── AI providers (at least one required for vibe review) ─────────────────────
BANANO_OPENROUTER_KEY=                # OpenRouter API key (primary provider)
ANTHROPIC_API_KEY=                    # Anthropic API key (fallback provider)

# ── Channel configuration ────────────────────────────────────────────────────
WATCHED_CHANNEL_IDS=                  # Comma-separated Discord channel IDs to monitor
                                      # e.g. 1234567890,9876543210
MOD_CHANNEL_ID=                       # Channel ID for mod escalation alerts

# ── Sentiment & review tuning ────────────────────────────────────────────────
SENTIMENT_THRESHOLD=-2                # AFINN score at or below triggers AI review (default: -2)
MAX_RECENT_MESSAGES=10                # Number of recent messages to include as context (default: 10)
MODERATOR_IDS=                        # Comma-separated Discord user IDs allowed to issue mod commands
COOLDOWN_MS=10000                     # Per-channel cooldown between actions in ms (default: 10000)
DEDUPE_WINDOW_MS=60000                # Window for message deduplication in ms (default: 60000)

# ── Escalation behaviour ─────────────────────────────────────────────────────
MOD_ESCALATION_MIN_SEVERITY=low       # Minimum severity to escalate to mod channel: low|medium|high
HIGH_SEVERITY_PUBLIC_REPLY=true       # Send public reply for high-severity violations (default: true)

# ── AI model configuration ───────────────────────────────────────────────────
VIBE_REVIEW_TIMEOUT_MS=30000          # Timeout per AI review call in ms (default: 30000)
VIBE_MODEL=                           # Primary model, e.g. openrouter/google/gemma-3-27b-it:free
                                      # Prefix with openrouter/ for OpenRouter, anthropic/ for Anthropic
