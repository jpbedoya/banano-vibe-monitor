# Banano Vibe Monitor — Standalone Bot Config
# Copy to .env and fill in values

# Required
DISCORD_BOT_TOKEN=your_discord_bot_token_here
BANANO_OPENROUTER_KEY=your_openrouter_api_key_here

# Channel IDs (comma-separated)
WATCHED_CHANNEL_IDS=1234567890123456789,9876543210987654321
MOD_CHANNEL_ID=1234567890123456789

# Tuning (optional — defaults shown)
SENTIMENT_THRESHOLD=-2
MAX_RECENT_MESSAGES=10
COOLDOWN_MS=30000
DEDUPE_WINDOW_MS=60000
CONTEXT_FILTER_BOTS=true

# Escalation (optional — defaults shown)
MOD_ESCALATION_MIN_SEVERITY=high
HIGH_SEVERITY_PUBLIC_REPLY=true

# AI review (optional — defaults shown)
VIBE_MODEL=openrouter/google/gemma-3-27b-it:free
VIBE_REVIEW_TIMEOUT_MS=30000

# Storage (optional — defaults to project root)
LOG_DIR=./logs
DATA_DIR=.
