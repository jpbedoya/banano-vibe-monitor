{
  "name": "banano-vibe",
  "version": "1.8.0",
  "description": "OpenClaw plugin for Banano's two-layer Discord vibe moderation",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node scripts/test.mjs",
    "deploy": "npm run build && cp -r dist/* ~/.openclaw/extensions/banano-vibe/dist/ && openclaw gateway restart",
    "logs": "node scripts/logs-summary.mjs",
    "logs:all": "node scripts/logs-summary.mjs --all",
    "logs:path": "echo ~/.openclaw/extensions/banano-vibe/logs"
  },
  "dependencies": {
    "sentiment": "^5.0.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^22.0.0"
  }
}
